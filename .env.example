# Contact form webhook (existing) — optional; the form still works without it,
# but submissions won't be forwarded to this endpoint.
CONTACT_WEBHOOK_URL=

# Supabase project — powers the CRM (companies/contacts/deals/tasks/notes),
# auth, and the admin/client dashboards. Values live in the Supabase dashboard
# under Project Settings > API for the project referenced in .mcp.json.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-only, never expose to the browser. Used to insert
# leads captured from the public contact form (which has no authenticated
# session) and to create client login accounts from the admin dashboard.
SUPABASE_SERVICE_ROLE_KEY=
